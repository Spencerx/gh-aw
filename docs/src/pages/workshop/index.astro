---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
	hasSidebar={false}
	frontmatter={{
		title: 'Workshop',
		description: 'The gh-aw workshop now lives in the gh-aw-workshop repository.',
		tableOfContents: false,
	}}
>
	<p>
		The full gh-aw workshop has moved to the
		<a href="https://github.com/githubnext/gh-aw-workshop">gh-aw-workshop repository</a>.
	</p>
	<p>
		Use that repository for the current workshop curriculum, supporting materials, and step-by-step
		exercises.
	</p>
</StarlightPage>
